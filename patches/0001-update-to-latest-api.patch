+    public int getX() {
+        return x;
+    }
+
+    public int getZ() {
+        return z;
+    }
+
+    public CMIDirection rotate90ClockWise() {
+        int a = this.getAngle() + 90;
+        a = a > 360 ? 360 - a : a;
+        return getFromAngle(a);
+    }
+
+    public CMIDirection rotate90CounterClockWise() {
+        int a = this.getAngle() - 90;
+        a = a < 0 ? 360 + a : a;
+        return getFromAngle(a);
+    }
+}
