+            CMIChatRoom room = roome.getValue();
+            if (room.isPersistent())
+                continue;
+            if (!room.getUsers().isEmpty())
+                continue;
+            if (room.getKeepAliveUntil() == 0L || room.getKeepAliveUntil() > System.currentTimeMillis())
+                continue;
+            iter.remove();
