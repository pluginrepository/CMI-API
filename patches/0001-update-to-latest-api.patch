+        add(key, value, null);
+    }
+
+    public void add(String key, String value, String defaultV) {
+    }
+
+    public void remove(String key) {
+        map.remove(key.toLowerCase());
+    }
+
+    public String getValue(String key) {
+        metaValues v = map.get(key.toLowerCase());
+        if (v == null)
+            return "";
+        return v.getValue();
