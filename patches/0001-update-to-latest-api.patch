+        return loc;
+    }
+
+    public List<String> getLines() {
+        return lines;
+    }
+
+    public String getLine(int place) {
+        return lines.size() - 1 < place || place < 0 ? "" : lines.get(place) == null ? "" : lines.get(place);
+    }
