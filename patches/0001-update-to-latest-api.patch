+        while (buffer.hasRemaining() && buffer.get() != 0) {
+        }
+
+        int end = buffer.position() - 1;
+        String str = null;
+        if (end > start) {
+            buffer.position(start);
+            buffer.limit(end);
+            str = charsetDecoder.decode(buffer).toString();
+            buffer.limit(oldLimit);
